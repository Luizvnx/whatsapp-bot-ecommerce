<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Favo de Mel</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-800 font-sans">

    <header class="bg-amber-500 text-white p-6 shadow-md">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <h1 class="text-2xl font-bold flex items-center gap-2">
                 🐝 Backoffice 
            </h1>
            <span id="badgeStatus" class="text-sm bg-gray-500 px-3 py-1 rounded-full text-white font-bold transition-colors">
                ⏳ Checando Conexão...
            </span>
        </div>
    </header>

    <main class="max-w-6xl mx-auto p-6 mt-6">
        <div id="alertaConexao" class="hidden mb-8 bg-red-50 border-2 border-red-200 p-8 rounded-xl shadow-md flex flex-col items-center text-center">
            <h3 class="text-2xl font-bold text-red-700 mb-2">⚠️ WhatsApp Desconectado!</h3>
            <p class="text-gray-700 mb-6 max-w-lg">
                O bot está offline. Isso acontece se o celular ficar sem internet ou se a sessão for encerrada. 
                <br><b>Escaneie o QR Code abaixo com o WhatsApp do suporte para reconectar:</b>
            </p>
            <div id="qrCodeContainer" class="bg-white p-4 rounded-xl shadow-sm border border-gray-200 min-h-[250px] min-w-[250px] flex items-center justify-center">
                <span class="text-gray-400 animate-pulse">Gerando QR Code...</span>
            </div>
        </div>
        <h2 class="text-xl font-semibold mb-6">Status dos Atendimentos</h2>
        
        <div id="statusGrid" class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <p class="text-gray-500 italic">⏳ Carregando dados da colmeia...</p>
        </div>
        <h2 class="text-xl font-semibold mb-4 mt-10 border-b pb-2">💬 Últimas Conversas com a IA</h2>
        
        <div id="conversasGrid" class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <p class="text-gray-500 italic">⏳ Puxando pergaminhos da colmeia...</p>
        </div>
    </main>

    <script>
        async function carregarEstatisticas() {
            try {
                const response = await fetch('/admin/stats');
                const result = await response.json();

                if (result.success) {
                    const grid = document.getElementById('statusGrid');
                    grid.innerHTML = ''; 

                    if(result.data.length === 0) {
                        grid.innerHTML = '<p class="text-gray-500">Nenhum atendimento no momento.</p>';
                        return;
                    }

                    result.data.forEach(item => {
                        const card = document.createElement('div');
                        card.className = 'bg-white p-6 rounded-lg shadow border border-amber-100 flex flex-col items-center justify-center';
                        card.innerHTML = `
                            <span class="text-4xl font-bold text-amber-600 mb-2">${item.total}</span>
                            <span class="text-gray-600 font-medium uppercase text-sm tracking-wider text-center">
                                ${item.etapa.replace(/_/g, ' ')}
                            </span>
                        `;
                        grid.appendChild(card);
                    });
                }
            } catch (error) {
                console.error("Erro ao carregar o dashboard:", error);
                document.getElementById('statusGrid').innerHTML = '<p class="text-red-500">Erro ao buscar dados do banco.</p>';
            }
        }

        async function carregarConversas() {
            try {
                const scrollGeral = window.scrollY;
                const scrollsDosChats = {};

                document.querySelectorAll('.caixa-chat').forEach(caixa => {
                    scrollsDosChats[caixa.id] = caixa.scrollTop;
                });

                const response = await fetch('/admin/conversas');
                const result = await response.json();

                if (result.success) {
                    const grid = document.getElementById('conversasGrid');
                    grid.innerHTML = ''; 

                    if(result.data.length === 0) {
                        grid.innerHTML = '<p class="text-gray-500">Nenhuma conversa registrada ainda.</p>';
                        return;
                    }

                    result.data.forEach(sessao => {
                        const dadosSessao = typeof sessao.dados_sessao === 'string' 
                            ? JSON.parse(sessao.dados_sessao) 
                            : (sessao.dados_sessao || {});
                            
                        const historico = dadosSessao.historicoIa || [];
                        let htmlMensagens = '';

                        if (historico.length === 0) {
                            htmlMensagens = '<p class="text-sm text-gray-400 italic">Nenhuma mensagem trocada com a IA.</p>';
                        } else {
                            const ultimasMsgs = historico.slice(-8);
                            ultimasMsgs.forEach(msg => {
                                const isUser = msg.role === 'user';
                                const corTexto = isUser ? 'text-blue-700' : 'text-amber-700';
                                const icone = isUser ? '👤 Cliente:' : '🤖 Bot:';
                                
                                htmlMensagens += `
                                    <div class="mb-2 pb-2 border-b border-gray-100 last:border-0">
                                        <span class="font-bold text-xs ${corTexto}">${icone}</span> 
                                        <p class="text-sm text-gray-700 mt-1">${msg.parts[0].text}</p>
                                    </div>
                                `;
                            });
                        }

                        const dataMsg = new Date(sessao.ultima_msg).toLocaleString('pt-BR');
                        
                        // Atualizado para usar id_cliente ao invés de telefone
                        const idCliente = sessao.id_cliente;
                        const nomeContato = sessao.nome_contato || 'Desconhecido';
                        const idSeguro = idCliente ? idCliente.replace(/\D/g, '') : Math.random().toString().substring(2, 10);
                        const numeroLimpo = sessao.id_cliente.split('@')[0];

                        const card = document.createElement('div');
                        card.className = 'bg-white p-5 rounded-lg shadow border border-gray-200';
                        
                        card.innerHTML = `
                            <div class="flex justify-between items-center mb-3 bg-gray-50 p-2 rounded border">
                                <div class="flex flex-col">
                                    <span class="font-bold text-gray-800">👤 ${sessao.nome_contato}</span>
                                    <span class="text-xs text-gray-500 font-mono">📱 ${numeroLimpo}</span>
                                </div>
                                <div class="text-right">
                                    <span class="block text-xs text-gray-500">${dataMsg}</span>
                                    <span class="block text-xs font-bold text-blue-600 uppercase mt-1">Etapa: ${sessao.etapa}</span>
                                </div>
                            </div> <div id="chat-${idSeguro}" class="caixa-chat bg-gray-50 p-4 rounded border h-48 overflow-y-auto mb-3">
                                ${htmlMensagens}
                            </div>
                            
                            <div class="flex gap-2 border-t pt-3">
                                <button onclick="alterarEtapaBot('${idCliente}', 'inicio')" 
                                        class="bg-gray-200 hover:bg-gray-300 text-gray-700 text-xs font-bold py-1 px-3 rounded transition">
                                    🔄 Resetar Bot
                                </button>
                                
                                <button onclick="alterarEtapaBot('${idCliente}', 'atendimento_humano')" 
                                        class="bg-blue-100 hover:bg-blue-200 text-blue-700 text-xs font-bold py-1 px-3 rounded transition ml-auto">
                                    ⏸️ Assumir Atendimento
                                </button>
                            </div>
                        `;
                        grid.appendChild(card);
                    });

                    window.scrollTo(0, scrollGeral);
                    
                    document.querySelectorAll('.caixa-chat').forEach(caixa => {
                        if (scrollsDosChats[caixa.id] !== undefined) {
                            caixa.scrollTop = scrollsDosChats[caixa.id];
                        } else {
                            caixa.scrollTop = caixa.scrollHeight;
                        }
                    });
                }
            } catch (error) {
                console.error("Erro ao carregar conversas:", error);
            }
        }

        async function alterarEtapaBot(id_cliente, novaEtapa) {
            const confirmacao = confirm(`Tem certeza que deseja mudar o cliente ${id_cliente} para a etapa: ${novaEtapa.toUpperCase()}?`);
            
            if (!confirmacao) return;

            try {
                const response = await fetch('/admin/alterar-status', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ id_cliente: id_cliente, novaEtapa: novaEtapa }) // Usando a chave 'id_cliente' para manter a consistência com a rota do Node
                });

                const result = await response.json();

                if (result.success) {
                    carregarConversas();
                    carregarEstatisticas(); 
                } else {
                    alert('Erro ao alterar o status do bot.');
                }
            } catch (error) {
                console.error('Erro na requisição:', error);
                alert('Erro de conexão com o servidor.');
            }
        }

        async function monitorarConexao() {
            try {
                const response = await fetch('/admin/instance-status');
                const result = await response.json();
                
                const badge = document.getElementById('badgeStatus');
                const alerta = document.getElementById('alertaConexao');
                const qrContainer = document.getElementById('qrCodeContainer');

                if (result.success) {
                    if (result.status === 'open') {
                        // Tudo certo, bot rodando!
                        badge.className = 'text-sm bg-green-500 px-3 py-1 rounded-full text-white font-bold transition-colors shadow-sm';
                        badge.innerHTML = '✅ Conectado';
                        alerta.classList.add('hidden');
                    } 
                    else if (result.status === 'qrcode') {
                        // Caiu a conexão, mostra o QR Code limpinho
                        badge.className = 'text-sm bg-red-600 px-3 py-1 rounded-full text-white font-bold transition-colors shadow-sm animate-pulse';
                        badge.innerHTML = '⚠️ Desconectado';
                        alerta.classList.remove('hidden');
                        qrContainer.innerHTML = `<img src="${result.qrCodeBase64}" alt="QR Code" class="w-64 h-64 object-contain">`;
                    } 
                    else {
                    badge.className = 'text-sm bg-black px-3 py-1 rounded-full text-white font-bold';
                    badge.innerHTML = '❌ Erro de API';
                }
                }
            } catch (error) {
                console.error("Erro ao verificar conexão:", error);
            }
        }

        // Inicia o monitoramento e verifica a cada 5 segundos
        monitorarConexao();
        setInterval(monitorarConexao, 5000);

        // Inicialização
        carregarConversas();
        setInterval(carregarConversas, 10000);

        carregarEstatisticas();
        setInterval(carregarEstatisticas, 10000);
    </script>
</body>
</html>